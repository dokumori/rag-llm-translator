# .env.defaults
#
# Committed defaults for environment variables whose values need a canonical
# fallback across shell scripts, Docker Compose, and Python services.
#
# These values are applied BEFORE .env, so anything in .env takes priority.
# Do NOT put secrets or machine-specific settings here.

EMBEDDING_MODEL_NAME=BAAI/bge-large-en-v1.5
DEFAULT_EMBEDDING_MODEL=BAAI/bge-large-en-v1.5

# All LLM traffic routes through the LiteLLM gateway (always required).
LLM_BASE_URL=http://litellm:4000/v1
