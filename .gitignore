# --- Operating System (macOS) ---
.DS_Store
.AppleDouble
.LSOverride
._*
.DocumentRevisions-V100
.fseventsd
.Spotlight-V100
.TemporaryItems
.Trashes
.VolumeIcon.icns
.com.apple.timemachine.donotpresent

# --- IDE (Visual Studio Code) ---
.vscode/*
# Uncomment the following lines if you want to share specific config with your team:
# !.vscode/settings.json
# !.vscode/tasks.json
# !.vscode/launch.json
# !.vscode/extensions.json
*.code-workspace

# --- Python ---
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# --- Virtual Environments ---
venv/
.venv/
env/
.env/
venv.bak/

# --- Environment Variables (Security) ---
# Matches .env, .env.local, .env-bk, .env.backup, .env_old, etc.
*.env*
# .env.defaults contains only non-secret defaults and IS committed to the repo.
!.env.defaults

# --- Docker ---
docker-compose.override.yml

# --- Project Logs ---
*.log
*.jsonl

# --- Project Data & Runtime ---
# Ignore most of the data directory where DBs and active files live,
# except for the ones required by the system
data/**
!data/**/
!data/**/.gitkeep


# Specific File Types
*.csv
*.po
*.pot
.tmp

# Ignore custom system prompt overrides
config/prompts/custom/*.md
!config/prompts/custom/.gitkeep

# Custom plugins are added as git submodules under services/toolbox/src/plugins/custom/.
# Their tests live inside the submodule itself (co-located).
services/toolbox/src/plugins/custom

# Pyrefly
pyrefly.toml

